{
  "uid": "osprey-red",
  "title": "Osprey RED",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Members - Request Rate",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"members\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Members - Error Rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"members\",code=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Members - p95 Latency",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"members\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
