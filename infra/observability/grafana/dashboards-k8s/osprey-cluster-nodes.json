{
  "uid": "osprey-cluster-nodes",
  "title": "Osprey Cluster - Nodes",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes Up",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "count(up{job=\"node-exporter\"} == 1)",
          "legendFormat": "nodes"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Logical CPUs",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "count(count by (cpu) (node_cpu_seconds_total))",
          "legendFormat": "cores"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Memory",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(node_memory_MemTotal_bytes)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load (1m)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(node_load1)",
          "legendFormat": "load1"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage % (per node)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Used % (per node)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Root Filesystem Used %",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"\"} * 100)",
          "legendFormat": "{{instance}} /"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Load Average",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "avg(node_load1)",
          "legendFormat": "1m"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "avg(node_load5)",
          "legendFormat": "5m"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "avg(node_load15)",
          "legendFormat": "15m"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network Throughput",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|cni.*|flannel.*\"}[5m]))",
          "legendFormat": "receive"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cali.*|cni.*|flannel.*\"}[5m]))",
          "legendFormat": "transmit"
        }
      ]
    }
  ]
}
