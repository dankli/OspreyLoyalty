{
  "uid": "osprey-cluster-pods",
  "title": "Osprey Cluster - Pods & Containers",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU by Namespace (cores)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory (working set) by Namespace",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"})",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU by Pod (osprey, cores)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"osprey\",container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory by Pod (osprey)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"osprey\",container!=\"\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Network Receive by Pod (osprey)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"osprey\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network Transmit by Pod (osprey)",
      "datasource": { "type": "prometheus", "uid": "osprey-prom" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "osprey-prom" },
          "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=\"osprey\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
