{
  "name": "route-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "node -r ./eslint.typescript-shim.cjs node_modules/eslint/bin/eslint.js .",
    "preview": "vite preview",
    "codegen": "graphql-codegen",
    "test": "vitest run",
    "build:wasm": "wasm-pack build wasm-map --target web --out-dir ../src/wasm/pkg --out-name wasm_map"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/parser": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/eslint-plugin": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/type-utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/tsconfig-utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/project-service": {
      "typescript": ">=4.8.4 <8"
    },
    "typescript-eslint": {
      "typescript": ">=4.8.4 <8"
    }
  },
  "dependencies": {
    "graphql": "^16.14.2",
    "graphql-request": "^7.4.0",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "typescript5": "npm:typescript@~5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wasm-pack": "^0.15.0"
  }
}
