{
  "name": "notifications",
  "version": "1.0.0",
  "description": "Email notifications for Osprey Loyalty member events (tier changes, expiring points)",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "node -r ./eslint.typescript-shim.cjs node_modules/eslint/bin/eslint.js .",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "license": "MIT",
  "type": "module",
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/parser": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/eslint-plugin": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/type-utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/tsconfig-utils": {
      "typescript": ">=4.8.4 <8"
    },
    "@typescript-eslint/project-service": {
      "typescript": ">=4.8.4 <8"
    },
    "typescript-eslint": {
      "typescript": ">=4.8.4 <8"
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.42.0",
    "amqplib": "^0.10.9",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "typescript5": "npm:typescript@~5.9.3",
    "vitest": "^4.1.10"
  }
}
